# Copy this file to `.env` or set these environment variables in your shell.
# Do NOT commit your real keys to version control.

# ThingSpeak API key (replace with your key)
THINGSPEAK_API_KEY=KXEBON70KLJQZAOX

# Flask secret key (use a long random string in production)
FLASK_SECRET_KEY=replace-with-a-secure-random-string

# Usage (PowerShell):
# $env:THINGSPEAK_API_KEY = 'your_real_key'
# $env:FLASK_SECRET_KEY = 'your_secret'
# python .\app.py
